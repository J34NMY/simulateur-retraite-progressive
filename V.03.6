    <!-- Colonne 3 : Retraite progressive -->
    <div class="col">
      <h3>Retraite progressive</h3>
      <label for="dateDebut">Date de départ retraite progressive</label>
      <input id="dateDebut" type="date" value="2025-12-01" />

      <label for="dateFin">Date de départ retraite définitive</label>
      <input id="dateFin" type="date" value="2027-07-01" />

      <label for="quotiteAvant">Quotité entre relevé et départ progressive</label>
      <select id="quotiteAvant">
        <option value="1.00">100 %</option>
        <option value="0.90">90 %</option>
        <option value="0.80" selected>80 %</option>
        <option value="0.70">70 %</option>
        <option value="0.60">60 %</option>
        <option value="0.50">50 %</option>
      </select>
      <small>Utilisée pour les LIQUIDABLES sur la période avant la progressive.</small>

      <label for="quotite">Quotité pendant la retraite progressive</label>
      <select id="quotite">
        <option value="0.90">90 % (32/35e)</option>
        <option value="0.80" selected>80 % (6/7e)</option>
        <option value="0.70">70 %</option>
        <option value="0.60">60 %</option>
        <option value="0.50">50 %</option>
      </select>
      <small>Règles spécifiques: 80% = 6/7e, 90% = 32/35e.</small>

      <!-- Bonification enfants avant 2004 -->
      <label class="bonif-label">
        <input type="checkbox" id="bonifEnfants">
        <span class="tooltip">ℹ️
          <span class="tooltiptext">
            Conditions :<br>
            • Enfant né ou adopté avant le 01/01/2004<br>
            • Interruption ou réduction d'activité pour élever l'enfant OU charge effective ≥ 9 ans avant ses 16 ans<br>
            • 2 ans de services effectifs dans la fonction publique<br>
            • Bonification : +4 trimestres liquidables par enfant
          </span>
        </span>
        <span>Je confirme remplir les conditions pour la bonification enfants nés/adoptés avant le 01/01/2004</span>
      </label>

      <label for="enfantsAvant2004">Nombre d'enfants</label>
      <input id="enfantsAvant2004" type="number" min="0" step="1" value="0" />
      <small>4 trimestres par enfant (ajoutés aux LIQUIDABLES uniquement).</small>
    </div>
  </div>

  <div class="actions">
  <button id="btnCalc">Calculer</button>
  <button id="btnDefault" class="secondary">Valeurs par défaut</button>
  <button id="btnExport" class="secondary">Exporter les paramètres</button>
  <input type="file" id="importFile" accept=".json" style="display:none;" />
<button id="btnImport" class="secondary">Importer les paramètres</button>
</div>


