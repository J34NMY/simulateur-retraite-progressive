  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

  <script>
    let chart;

    // === Barème de surcotisation ===
    const baremeSurcotisation = {
      "0.50": 23.85,
      "0.60": 21.30,
      "0.70": 18.75,
      "0.80": 16.20,
      "0.90": 13.65
    };
	
    // === Utilitaires ===
    function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }
    function formatEuro(x){ return (isFinite(x)?x:0).toFixed(2) + ' €'; }
    function joursEnTrimestres(jours){ return (parseFloat(jours)||0) / 90; }
    function diffJours(d1, d2){
      if (!(d1 instanceof Date) || !(d2 instanceof Date) || isNaN(d1) || isNaN(d2)) return 0;
      const msParJour = 1000*60*60*24;
      return Math.floor((d2 - d1) / msParJour);
    }
    function diffDetaillee(d1,d2){
      const totalJours = Math.max(0, diffJours(d1,d2));
      const annees = Math.floor(totalJours / 365.25);
      const resteApresAns = totalJours - Math.floor(annees * 365.25);
      const mois = Math.floor(resteApresAns / 30.4375);
      const jours = Math.max(0, Math.floor(resteApresAns - mois * 30.4375));
      const anneesDec = totalJours / 365.25;
      const moisApprox = totalJours / 30.4375;
      return { annees, mois, jours, totalJours, anneesDec, moisApprox };
    }

    // === Barème trimestres requis (corrigé selon retraitesdeletat.gouv.fr) ===
    const trimestresParAnnee = [
      { min: 1958, max: 1960, trimestres: 163 },
      { min: 1961, max: 1961, trimestres: 169 }, // Corrigé selon les informations fournies
      { min: 1962, max: 1962, trimestres: 169 }, // Corrigé selon les informations fournies
      { min: 1963, max: 1963, trimestres: 170 }, // Corrigé selon les informations fournies
      { min: 1964, max: 1964, trimestres: 171 }, // Corrigé selon les informations fournies
      { min: 1965, max: 2100, trimestres: 172 }  // Corrigé selon les informations fournies
    ];

    function autoRemplirTrimestres(dateNaissance) {
      if (!(dateNaissance instanceof Date) || isNaN(dateNaissance)) return '';
      const annee = dateNaissance.getFullYear();
      
      for (const r of trimestresParAnnee) {
        if (annee >= r.min && annee <= r.max) {
          return r.trimestres;
        }
      }
      return '';
    }

    // === Traitement et pension ===
    function calcTraitementPlein(indice, valeurPoint){ return indice * valeurPoint; }
    function calcMontantReference(traitementPlein, trimLiquidables, trimRequis){
      const ratio = clamp(trimLiquidables/trimRequis, 0, 1);
      const taux = 0.75 * ratio;
      return { taux, montant: traitementPlein * taux };
    }
    function calcTraitementTP(traitementPlein, quotite){
      if (Math.abs(quotite - 0.80) < 1e-9) return traitementPlein * (6/7);
      if (Math.abs(quotite - 0.90) < 1e-9) return traitementPlein * (32/35);
      return traitementPlein * quotite;
    }
    function calcRevenusProgressive({ indice, valeurPoint, trimLiquidablesDepart, trimRequis, quotite }){
      const traitementPlein = calcTraitementPlein(indice, valeurPoint);
      const ref = calcMontantReference(traitementPlein, trimLiquidablesDepart, trimRequis);
      const traitementTP = calcTraitementTP(traitementPlein, quotite);
      const pensionProvisoire = ref.montant * (1 - quotite);
      const total = traitementTP + pensionProvisoire;
      return { traitementPlein, traitementTP, pensionProvisoire, total, tauxRef: ref.taux, montantRef: ref.montant };
    }

    // === Lecture inputs ===
    function lireInputs() {
      const indice = parseFloat(document.getElementById('indice').value) || 0;
      const valeurPoint = parseFloat(document.getElementById('valeurPoint').value) || 0;
      const tauxSurcotisation = parseFloat(document.getElementById('tauxSurcotisation').value) / 100 || 0.107;
      const dateReleve = new Date(document.getElementById('dateReleve').value);
      const trimAssuranceReleve = parseFloat(document.getElementById('trimAssuranceReleve').value) || 0;
      const joursAssuranceReleve = parseFloat(document.getElementById('joursAssuranceReleve').value) || 0;
      const trimLiquidablesReleve = parseFloat(document.getElementById('trimLiquidablesReleve').value) || 0;
      const joursLiquidablesReleve = parseFloat(document.getElementById('joursLiquidablesReleve').value) || 0;
      
      let trimestresRequis = parseFloat(document.getElementById('trimestresRequis').value);
      if (!trimestresRequis) {
        const dateNaissance = new Date(document.getElementById('dateNaissance').value);
        trimestresRequis = autoRemplirTrimestres(dateNaissance) || 0;
      }

      const dateDebutStr = document.getElementById('dateDebut').value;
      const dateFinStr = document.getElementById('dateFin').value;
      const dateDebut = dateDebutStr ? new Date(dateDebutStr) : new Date(NaN);
      const dateFin = dateFinStr ? new Date(dateFinStr) : new Date(NaN);

      const quotiteAvant = parseFloat(document.getElementById('quotiteAvant').value);
      const quotite = parseFloat(document.getElementById('quotite').value);
      const surcotisation = document.getElementById('surcotisation').checked;

      const bonifEnfants = document.getElementById('bonifEnfants').checked;
      const nbEnfants = parseInt(document.getElementById('enfantsAvant2004').value || '0', 10);

      const dateNaissance = document.getElementById('dateNaissance').value
        ? new Date(document.getElementById('dateNaissance').value)
        : new Date(NaN);

      return {
        indice,
        valeurPoint,
        tauxSurcotisation,
        dateReleve,
        trimAssuranceReleve,
        joursAssuranceReleve,
        trimLiquidablesReleve,
        joursLiquidablesReleve,
        trimestresRequis,
        dateDebut,
        dateFin,
        quotiteAvant,
        quotite,
        surcotisation,
        nbEnfantsAvant2004: nbEnfants,
        conditionsEnfantsAvant2004: bonifEnfants,
        dateNaissance
      };
    }

    // === Mise à jour automatique du taux de surcotisation ===
    function mettreAJourTauxSurcotisation() {
      const quotite = document.getElementById('quotite').value;
      const surcotisationCochee = document.getElementById('surcotisation').checked;
      const tauxSurcotisationInput = document.getElementById('tauxSurcotisation');
      const tauxContainer = document.getElementById('tauxSurcotisationContainer');
      
      // Afficher ou masquer le champ de taux selon l'état de la case
      if (surcotisationCochee) {
        tauxContainer.classList.remove('hidden');
        
        // Mettre à jour la valeur si elle n'a pas été modifiée manuellement
        if (baremeSurcotisation[quotite] && !tauxSurcotisationInput.dataset.manual) {
          tauxSurcotisationInput.value = baremeSurcotisation[quotite];
        }
      } else {
        tauxContainer.classList.add('hidden');
      }
    }
function initVariables(I, TR) {
  const bonifEnfantsJours = I.conditionsEnfantsAvant2004 ? I.nbEnfantsAvant2004 * 4 * 90 : 0;

  const joursAssReleve = Math.floor((I.trimAssuranceReleve + joursEnTrimestres(I.joursAssuranceReleve)) * 90);
  const joursLiqReleve = Math.floor((I.trimLiquidablesReleve + joursEnTrimestres(I.joursLiquidablesReleve)) * 90);

  const P1 = diffDetaillee(I.dateReleve, I.dateDebut);
  const P2 = diffDetaillee(I.dateDebut, I.dateFin);

  const joursAssP1 = P1.totalJours;
  const joursAssP2 = P2.totalJours;
  const joursLiqP1 = Math.floor(P1.totalJours * I.quotiteAvant);
  const joursLiqP2 = Math.floor(P2.totalJours * (I.surcotisation ? 1 : I.quotite));

  return {
    bonifEnfantsJours,
    joursAssReleve,
    joursLiqReleve,
    joursAssP1,
    joursAssP2,
    joursLiqP1,
    joursLiqP2,
    P1,
    P2,
    TR
  };
}
function calculTauxFinal(I, V) {
  const assuranceFinale = Math.floor((V.joursAssReleve + V.joursAssP1 + V.joursAssP2 + V.bonifEnfantsJours) / 90);
  const liquidablesFinale = Math.floor((V.joursLiqReleve + V.joursLiqP1 + V.bonifEnfantsJours + V.joursLiqP2) / 90);
  const ratioFin = clamp(liquidablesFinale / V.TR, 0, 1);
  const ageDepartDefinitif = (I.dateFin - I.dateNaissance) / (1000 * 60 * 60 * 24 * 365.25);

  let tauxFinal = 0.75 * ratioFin;
  let tauxSurcote = 0;
  let trimestresSurcotes = 0;
  let surcoteAppliquee = false;

  if (assuranceFinale < V.TR) {
    const trimestresManquants = V.TR - assuranceFinale;
    const tauxDecoteParTrim = I.dateNaissance.getFullYear() >= 1964 ? 1.09 : 1.25;
    const decoteTotale = trimestresManquants * tauxDecoteParTrim;
    tauxFinal = Math.max(0, (75 - decoteTotale)) / 100 * ratioFin;
  }

  if (assuranceFinale >= V.TR && ageDepartDefinitif > 62 && ageDepartDefinitif < 67) {
    trimestresSurcotes = Math.floor((ageDepartDefinitif - 62) * 4);
    tauxSurcote = trimestresSurcotes * 1.25;
    tauxFinal = Math.min(75 + tauxSurcote, 80) / 100 * ratioFin;
    surcoteAppliquee = true;
  }

  return {
    tauxFinal,
    tauxSurcote,
    trimestresSurcotes,
    surcoteAppliquee,
    assuranceFinale,
    liquidablesFinale,
    ratioFin,
    ageDepartDefinitif
  };
}
function affichageUI(I, V, T, revenus) {
  const res = document.getElementById('resultat');
  res.innerHTML = `
    <div class="info">
      <strong>Résumé pédagogique :</strong><br>
      Vous partez à <strong>${T.ageDepartDefinitif.toFixed(1)} ans</strong> avec <strong>${T.assuranceFinale}</strong> trimestres d’assurance.<br>
      ${T.surcoteAppliquee ? `→ ✅ Surcote appliquée : +${T.tauxSurcote.toFixed(2)} %<br>` : ''}
      ${T.assuranceFinale >= V.TR ? `→ ✅ Décote évitée : assurance ≥ requis<br>` : `→ ⚠️ Décote appliquée : ${V.TR - T.assuranceFinale} trimestres manquants<br>`}
      ${I.surcotisation ? `→ ✅ Surcotisation activée : +${(V.joursLiqP2 / 90).toFixed(2)} trimestres, coût estimé : ${formatEuro(I.salaireMensuel * I.quotite * 0.15 * V.P2.nbMois)}` : ''}
    </div>
    <h3>Situation en fin de période</h3>
    <p><strong>Assurance finale:</strong> ${T.assuranceFinale} / ${V.TR}</p>
    <p><strong>Liquidables finaux:</strong> ${T.liquidablesFinale} / ${V.TR}</p>
    <p><strong>Taux de liquidation estimé:</strong> ${(T.tauxFinal * 100).toFixed(2)} %</p>
    ${(T.surcoteAppliquee) ? `<p class="muted">→ Surcote appliquée : +${T.tauxSurcote.toFixed(2)} % pour ${T.trimestresSurcotes} trimestre(s) supplémentaires après 62 ans.</p>` : ''}
    <p><strong>Pension définitive estimée:</strong> ${formatEuro(I.indice * I.valeurPoint * T.tauxFinal)}</p>
    <p class="muted">⚠️ Estimation indicative. Consultez votre service RH pour validation réglementaire.</p>
  `;
}


    // === Calcul principal ===
    function calculer() {
	  const I = lireInputs();
  const TR = autoRemplirTrimestres(I.dateNaissance) || I.trimestresRequis;

  const variables = initVariables(I, TR);
  const taux = calculTauxFinal(I, variables);
  const revenus = calcRevenusProgressive({
    indice: I.indice,
    valeurPoint: I.valeurPoint,
    trimLiquidablesDepart: Math.floor((variables.joursLiqReleve + variables.joursLiqP1 + variables.bonifEnfantsJours) / 90),
    trimRequis: TR,
    quotite: I.quotite
  });

  affichageUI(I, variables, taux, revenus);


document.getElementById('importFile').addEventListener('change', (event) => {
  const file = event.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const data = JSON.parse(e.target.result);
      importerParametresUtilisateur(data);
    } catch (err) {
      alert("Fichier invalide ou corrompu.");
    }
  };
  reader.readAsText(file);
});
});
  </script>
