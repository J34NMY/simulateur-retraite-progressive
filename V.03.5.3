  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

  <script>
    let chart;

    // === Barème de surcotisation ===
    const baremeSurcotisation = {
      "0.50": 23.85,
      "0.60": 21.30,
      "0.70": 18.75,
      "0.80": 16.20,
      "0.90": 13.65
    };
	
    // === Utilitaires ===
    function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }
    function formatEuro(x){ return (isFinite(x)?x:0).toFixed(2) + ' €'; }
    function joursEnTrimestres(jours){ return (parseFloat(jours)||0) / 90; }
    function diffJours(d1, d2){
      if (!(d1 instanceof Date) || !(d2 instanceof Date) || isNaN(d1) || isNaN(d2)) return 0;
      const msParJour = 1000*60*60*24;
      return Math.floor((d2 - d1) / msParJour);
    }
    function diffDetaillee(d1,d2){
      const totalJours = Math.max(0, diffJours(d1,d2));
      const annees = Math.floor(totalJours / 365.25);
      const resteApresAns = totalJours - Math.floor(annees * 365.25);
      const mois = Math.floor(resteApresAns / 30.4375);
      const jours = Math.max(0, Math.floor(resteApresAns - mois * 30.4375));
      const anneesDec = totalJours / 365.25;
      const moisApprox = totalJours / 30.4375;
      return { annees, mois, jours, totalJours, anneesDec, moisApprox };
    }

    // === Barème trimestres requis (corrigé selon retraitesdeletat.gouv.fr) ===
    const trimestresParAnnee = [
      { min: 1958, max: 1960, trimestres: 163 },
      { min: 1961, max: 1961, trimestres: 169 }, // Corrigé selon les informations fournies
      { min: 1962, max: 1962, trimestres: 169 }, // Corrigé selon les informations fournies
      { min: 1963, max: 1963, trimestres: 170 }, // Corrigé selon les informations fournies
      { min: 1964, max: 1964, trimestres: 171 }, // Corrigé selon les informations fournies
      { min: 1965, max: 2100, trimestres: 172 }  // Corrigé selon les informations fournies
    ];

    function autoRemplirTrimestres(dateNaissance) {
      if (!(dateNaissance instanceof Date) || isNaN(dateNaissance)) return '';
      const annee = dateNaissance.getFullYear();
      
      for (const r of trimestresParAnnee) {
        if (annee >= r.min && annee <= r.max) {
          return r.trimestres;
        }
      }
      return '';
    }

    // === Traitement et pension ===
    function calcTraitementPlein(indice, valeurPoint){ return indice * valeurPoint; }
    function calcMontantReference(traitementPlein, trimLiquidables, trimRequis){
      const ratio = clamp(trimLiquidables/trimRequis, 0, 1);
      const taux = 0.75 * ratio;
      return { taux, montant: traitementPlein * taux };
    }
    function calcTraitementTP(traitementPlein, quotite){
      if (Math.abs(quotite - 0.80) < 1e-9) return traitementPlein * (6/7);
      if (Math.abs(quotite - 0.90) < 1e-9) return traitementPlein * (32/35);
      return traitementPlein * quotite;
    }
    function calcRevenusProgressive({ indice, valeurPoint, trimLiquidablesDepart, trimRequis, quotite }){
      const traitementPlein = calcTraitementPlein(indice, valeurPoint);
      const ref = calcMontantReference(traitementPlein, trimLiquidablesDepart, trimRequis);
      const traitementTP = calcTraitementTP(traitementPlein, quotite);
      const pensionProvisoire = ref.montant * (1 - quotite);
      const total = traitementTP + pensionProvisoire;
      return { traitementPlein, traitementTP, pensionProvisoire, total, tauxRef: ref.taux, montantRef: ref.montant };
    }

