      document.getElementById('dateDebut').value = '2025-12-01';
      document.getElementById('dateFin').value = '2027-07-01';

      // Quotités
      document.getElementById('quotiteAvant').value = "0.80";
      document.getElementById('quotite').value = "0.80";

      // Paramètres
      document.getElementById('surcotisation').checked = false;
      document.getElementById('tauxSurcotisation').value = "10.7";
      delete document.getElementById('tauxSurcotisation').dataset.manual;
      mettreAJourTauxSurcotisation();

      // Enfants avant 2004
      document.getElementById('bonifEnfants').checked = false;
      const nb = document.getElementById('enfantsAvant2004');
      nb.value = '';
      nb.disabled = true;

      calculer();  
}	
/**
 * Exporte les paramètres utilisateur dans un fichier .json.
 * Inclut les métadonnées réglementaires pour traçabilité.
 * Utilisé pour archivage, partage ou rechargement ultérieur.
 */
function exporterParametresUtilisateur() {
  console.log("Export lancé !"); // Vérification console

  // Lecture des paramètres saisis par l'utilisateur
  const inputs = lireInputs();

  // Métadonnées réglementaires associées à l'export
  const metadata = {
    version: "V.03.5.3", // Version du simulateur
    decret: "Décret n° 2025‑681 du 15 juillet 2025", // Référence réglementaire
    dateExport: new Date().toISOString() // Horodatage ISO
  };

  // Fusion des données utilisateur + métadonnées
  const exportData = { ...inputs, ...metadata };

  // Création du fichier JSON à télécharger
  const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);

  // Déclenchement du téléchargement
  const a = document.createElement('a');
  a.href = url;
  a.download = 'parametres_simulateur.json';
  a.click();

  // Nettoyage de l'URL temporaire
  URL.revokeObjectURL(url);
}

function importerParametresUtilisateur(jsonData) {
  if (!jsonData) return;

  document.getElementById('indice').value = jsonData.indice;
  document.getElementById('valeurPoint').value = jsonData.valeurPoint;
  document.getElementById('tauxSurcotisation').value = (jsonData.tauxSurcotisation * 100).toFixed(1);
  document.getElementById('dateReleve').value = jsonData.dateReleve?.slice(0, 10);
  document.getElementById('trimAssuranceReleve').value = jsonData.trimAssuranceReleve;
  document.getElementById('joursAssuranceReleve').value = jsonData.joursAssuranceReleve;
  document.getElementById('trimLiquidablesReleve').value = jsonData.trimLiquidablesReleve;
  document.getElementById('joursLiquidablesReleve').value = jsonData.joursLiquidablesReleve;
  document.getElementById('dateNaissance').value = jsonData.dateNaissance?.slice(0, 10);
  document.getElementById('dateDebut').value = jsonData.dateDebut?.slice(0, 10);
  document.getElementById('dateFin').value = jsonData.dateFin?.slice(0, 10);
  document.getElementById('quotiteAvant').value = jsonData.quotiteAvant;
  document.getElementById('quotite').value = jsonData.quotite;
  document.getElementById('surcotisation').checked = jsonData.surcotisation;
  document.getElementById('bonifEnfants').checked = jsonData.conditionsEnfantsAvant2004;
  document.getElementById('enfantsAvant2004').value = jsonData.nbEnfantsAvant2004;

  const val = autoRemplirTrimestres(new Date(jsonData.dateNaissance));
  const trSelect = document.getElementById('trimestresRequis');
  trSelect.innerHTML = val ? `<option value="${val}" selected>${val}</option>` : `<option value="">-- Non défini --</option>`;

  mettreAJourTauxSurcotisation();
  calculer();
}

  

    // =======================
// Initialisation du formulaire au chargement
// =======================
    window.addEventListener('DOMContentLoaded', () => {
	// Gestion de l'état du champ "nombre d'enfants" selon la case cochée
      const caseBonif = document.getElementById("bonifEnfants");
      const champNbEnfants = document.getElementById("enfantsAvant2004");
      champNbEnfants.disabled = !caseBonif.checked;
      
      // Initialisation des trimestres requis selon la date de naissance
      const dateNaissance = document.getElementById('dateNaissance').value;
      if (dateNaissance) {
        const val = autoRemplirTrimestres(new Date(dateNaissance));
        const trSelect = document.getElementById('trimestresRequis');
        trSelect.innerHTML = val ? `<option value="${val}" selected>${val}</option>` : `<option value="">-- Non défini --</option>`;
      }
      
     // Mise à jour du taux de surcotisation si champ modifié
      mettreAJourTauxSurcotisation();
	 // Calcul initial automatique        
      calculer(); 
	  
	  // Liaison du bouton Export à la fonction d’export
	  document.getElementById('btnExport').addEventListener('click', exporterParametresUtilisateur);
	  document.getElementById('btnImport').addEventListener('click', () => {
  document.getElementById('importFile').click();
});

document.getElementById('importFile').addEventListener('change', (event) => {
  const file = event.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const data = JSON.parse(e.target.result);
      importerParametresUtilisateur(data);
    } catch (err) {
      alert("Fichier invalide ou corrompu.");
    }
  };
  reader.readAsText(file);
});
});
